{
	"name": "DF_FOR_AGENCYCSV_TO_SYNAPSE_AGENCY_MD",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_AgencyMaster",
						"type": "DatasetReference"
					},
					"name": "DSAgencyMasterCsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_AGENCY_MD",
						"type": "DatasetReference"
					},
					"name": "SynapseDSAgencyMD"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          AgencyID as integer,",
				"          AgencyName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> DSAgencyMasterCsv",
				"DSAgencyMasterCsv sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          AgencyID as string,",
				"          AgencyName as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          AgencyID,",
				"          AgencyName",
				"     )) ~> SynapseDSAgencyMD"
			]
		}
	}
}